{
  "name": "kensington",
  "version": "2.0.0-signals.5",
  "description": "HTML/SVG/MathML template library for Node.js and the browser",
  "type": "module",
  "types": "./types.d.ts",
  "sideEffects": false,
  "license": "ISC",
  "bin": {
    "kensington": "bin/html-to-kensington.js"
  },
  "files": [
    "bin",
    "esm",
    "cjs",
    "dist",
    "types.d.ts",
    "attributes.d.ts",
    "llms.txt",
    "AGENTS.md"
  ],
  "typesVersions": {
    "*": {
      "attributes": [
        "./attributes.d.ts"
      ]
    }
  },
  "llms": "./llms.txt",
  "exports": {
    "./package.json": "./package.json",
    "./llms.txt": "./llms.txt",
    "./dist": "./dist/kensington.js",
    "./dist/min": "./dist/kensington.min.js",
    "./dist/slim": "./dist/kensington.slim.js",
    "./dist/slim/min": "./dist/kensington.slim.min.js",
    "./attributes": {
      "types": "./attributes.d.ts",
      "import": "./esm/attributes.js",
      "require": "./cjs/attributes.js"
    },
    ".": {
      "import": {
        "types": "./types.d.ts",
        "default": "./esm/index.js"
      },
      "require": {
        "types": "./types.d.ts",
        "default": "./cjs/index.js"
      }
    }
  },
  "keywords": [
    "template",
    "markup",
    "javascript",
    "express",
    "html"
  ],
  "author": {
    "name": "Ryan Lee Simms",
    "url": "https://www.ryansimms.com"
  },
  "homepage": "https://github.com/ryanlsimms/kensington#readme",
  "bugs": "https://github.com/ryanlsimms/kensington/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanlsimms/kensington.git"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "prepack": "node generate/bin/build-cjs.js && node generate/bin/build-browser.js",
    "build": "(cd generate/bin && node write-code-files.js) && eslint esm/kensington.js esm/attributes.js",
    "lint": "eslint .",
    "build-cjs": "node generate/bin/build-cjs.js",
    "build-browser": "node generate/bin/build-browser.js",
    "fetch": "node generate/bin/fetch-all.js",
    "fetch-and-build": "npm run fetch && npm run build",
    "test": "npm run test-esm && npm run test-cjs && npm run test-ts && npm run test-browser && npm run test-cli && echo 'All tests passed'",
    "test-browser": "npx playwright test --config ./tests/browser/config/playwright.config.js && npm run stop-server",
    "stop-server": "pkill -f html-server.js || true",
    "test-esm": "node --test \"./tests/esm/esm-test.js\"",
    "test-cjs": "node --test \"./tests/cjs/cjs-test.js\"",
    "test-ts": "tsc --noEmit -p tests/typescript/tsconfig.json && echo 'TypeScript types OK'",
    "test-cli": "node --test \"./tests/html-to-kensington-test.js\"",
    "benchmark": "node tests/benchmark.js",
    "dom-server": "node --watch-path=./tests/browser/pages --watch-path=./esm ./tests/browser/server/html-server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "23.9.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run build && git add esm/kensington.js esm/attributes.js types.d.ts attributes.d.ts && npx lint-staged",
    "post-checkout": "if [ \"$3\" = \"1\" ]; then node generate/bin/build-cjs.js && node generate/bin/build-browser.js; fi"
  },
  "lint-staged": {
    "*.js": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@types/node": "^25.5.0",
    "@webref/css": "^8.5.5",
    "@webref/idl": "^3.77.0",
    "eslint": "^9.39.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "html-validate": "^9.4.1",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.2.7",
    "rollup": "^4.35.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "csstype": "^3.2.3",
    "parse5": "^8.0.1"
  }
}
