{
  "name": "kensington",
  "version": "0.11.1",
  "main": "./cjs/kensington.js",
  "type": "module",
  "module": "./esm/kensington.js",
  "types": "./types.d.ts",
  "license": "ISC",
  "exports": {
    "./package.json": "./package.json",
    "./attributes": {
      "import": "./esm/attributes.js",
      "require": "./cjs/attributes.js"
    },
    ".": {
      "import": {
        "default": "./esm/kensington.js",
        "types": "./types.d.ts"
      },
      "require": {
        "default": "./cjs/kensington.js",
        "types": "./types.d.ts"
      }
    }
  },
  "keywords": [
    "template",
    "markup",
    "javascript",
    "express",
    "html"
  ],
  "author": {
    "name": "Ryan Lee Simms",
    "url": "https://www.ryansimms.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanlsimms/kensington.git"
  },
  "scripts": {
    "test": "node --test \"./tests/esm/esm-test.js\"",
    "test-dom": "npx playwright test --config ./tests/browser/playwright.config.js",
    "dom-server": "node --watch-path=./tests/browser/pages --watch-path=./esm ./tests/browser/server/html-server.js"
  },
  "dependencies": {
    "he": "^1.2.0"
  },
  "volta": {
    "node": "23.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.5.0",
    "html-validate": "^9.4.1",
    "jsdom": "^26.0.0",
    "rollup": "^4.35.0"
  }
}
