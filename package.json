{
  "name": "kensington",
  "version": "0.12.0",
  "description": "HTML/SVG/MathML template engine for Node.js and the browser",
  "type": "module",
  "types": "./types.d.ts",
  "sideEffects": false,
  "license": "ISC",
  "files": [
    "esm",
    "cjs",
    "dist",
    "types.d.ts",
    "attributes.d.ts"
  ],
  "typesVersions": {
    "*": { "attributes": ["./attributes.d.ts"] }
  },
  "exports": {
    "./package.json": "./package.json",
    "./dist": "./dist/kensington.js",
    "./dist/min": "./dist/kensington.min.js",
    "./dist/slim": "./dist/kensington.slim.js",
    "./dist/slim/min": "./dist/kensington.slim.min.js",
    "./attributes": {
      "types": "./attributes.d.ts",
      "import": "./esm/attributes.js",
      "require": "./cjs/attributes.js"
    },
    ".": {
      "import": {
        "types": "./types.d.ts",
        "default": "./esm/kensington.js"
      },
      "require": {
        "types": "./types.d.ts",
        "default": "./cjs/kensington.js"
      }
    }
  },
  "keywords": [
    "template",
    "markup",
    "javascript",
    "express",
    "html"
  ],
  "author": {
    "name": "Ryan Lee Simms",
    "url": "https://www.ryansimms.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanlsimms/kensington.git"
  },
  "scripts": {
    "prepack": "node generate/bin/build-cjs.js && node generate/bin/build-browser.js",
    "build": "cd generate/bin && node write-code-files.js",
    "build-cjs": "node generate/bin/build-cjs.js",
    "build-browser": "node generate/bin/build-browser.js",
    "fetch": "node generate/bin/fetch-all.js",
    "fetch-and-build": "npm run fetch && npm run build",
    "test": "npm run test-esm && npm run test-cjs && npm run test-ts && npm run test-browser && echo 'All tests passed'",
    "test-browser": "npx playwright test --config ./tests/browser/playwright.config.js",
    "test-esm": "node --test \"./tests/esm/esm-test.js\"",
    "test-cjs": "node --test \"./tests/cjs/cjs-test.js\"",
    "test-ts": "tsc --noEmit -p tests/typescript/tsconfig.json && echo 'TypeScript types OK'",
    "benchmark": "node tests/benchmark.js",
    "dom-server": "node --watch-path=./tests/browser/pages --watch-path=./esm ./tests/browser/server/html-server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "23.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^25.5.0",
    "html-validate": "^9.4.1",
    "jsdom": "^26.0.0",
    "rollup": "^4.35.0",
    "typescript": "^6.0.3"
  }
}
